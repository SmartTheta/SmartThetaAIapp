# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/smarttheta

# Gmail OTP (Email)
# Enable 2FA in Google Account, then: Security → App Passwords → generate one
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Fast2SMS (SMS OTP - Indian numbers only)
# Sign up free at https://www.fast2sms.com → Dev API → copy API Key
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# Other APIs
EODHD_API_KEY=your_eodhd_api_key_here
GOOGLE_SHEETS_ID=your_google_sheets_id
GOOGLE_API_KEY=your_google_api_key

# Server
PORT=5000
NODE_ENV=development
